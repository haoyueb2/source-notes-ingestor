# Paths
OBSIDIAN_VAULT_PATH=/absolute/path/to/vault
RAW_DATA_DIR=./samples
STATE_DIR=./state
ASSET_DIR_NAME=Sources/_assets
SYNC_STATE_DIR_NAME=Sources/_state

# Scheduling
SYNC_INTERVAL_MINUTES=60
FULL_SYNC_ON_FIRST_RUN=true

# Zhihu auth and targeting
ZHIHU_COOKIE=
ZHIHU_USER_AGENT=
ZHIHU_TARGET_URL=

# WeChat auth and targeting
WECHAT_COOKIE=
WECHAT_TOKEN=
WECHAT_ACCOUNT_ID=
WECHAT_ACCOUNT_NAME=

# Runtime flags
LOG_LEVEL=info
DRY_RUN=false
